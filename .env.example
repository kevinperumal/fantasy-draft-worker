# Same cloud Postgres instance as the backend
DATABASE_URL=postgres://user:password@host:5432/draftpilot

# Set to 'false' only if Postgres is local without SSL
DATABASE_SSL=true

# Backend URL — used by the injected script to POST /picks
BACKEND_URL=https://your-backend-url.example.com

# Path to Chromium on the Pi (find with: which chromium-browser)
CHROME_PATH=/usr/bin/chromium-browser

# Slow down Puppeteer interactions (ms) — helps with stability on Pi
LOGIN_SLOWMO_MS=50
